# Variables de Entorno - Dental Bosch API

# Entorno
NODE_ENV=production

# Base de Datos
MONGODB_URI_PRODUCTION=mongodb+srv://username:password@cluster.mongodb.net/dental_bosch?retryWrites=true&w=majority
MONGODB_URI_LOCAL=mongodb://localhost:27017/dental_bosch

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRE=7d

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=consultoriodbosch@gmail.com

# Google OAuth (Opcional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Servidor
PORT=5000

# CORS (Opcional)
CORS_ORIGINS=https://yourdomain.com,https://anotherdomain.com
